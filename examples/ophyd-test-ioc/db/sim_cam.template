# Macros: P, R, PORT, IOC
# MovingDot area detector template for ophyd-test-ioc.
#
# Includes the full ADBase (NDArrayBase -> ADBase) record set for standard
# areaDetector PVs (TriggerMode, Gain, Shutter, Temperature, etc.), then
# adds MovingDot-specific records for motor positions and beam current.

include "ADBase.template"

# ===== MovingDot-specific: Motor positions + beam current + shutter =====
# CP link receivers are Soft Channel — DB access only, no asyn round-trip.
# They forward to asyn records via OUT PP, matching C ADCore NDOverlayN pattern.

record(ao, "$(P)$(R)MotorXPosLink") {
    field(OMSL, "closed_loop")
    field(DOL,  "$(P)dot:mtrx.RBV CP")
    field(OUT,  "$(P)$(R)MotorXPos PP")
    field(PREC, "4")
}

record(ao, "$(P)$(R)MotorXPos") {
    field(DTYP, "asynFloat64")
    field(OUT,  "@asyn($(PORT),$(ADDR=0),$(TIMEOUT=1))DOT_MOTOR_X_POS")
    field(PREC, "4")
}

record(ai, "$(P)$(R)MotorXPos_RBV") {
    field(DTYP, "asynFloat64")
    field(INP,  "@asyn($(PORT),$(ADDR=0),$(TIMEOUT=1))DOT_MOTOR_X_POS")
    field(SCAN, "I/O Intr")
    field(PREC, "4")
}

record(ao, "$(P)$(R)MotorYPosLink") {
    field(OMSL, "closed_loop")
    field(DOL,  "$(P)dot:mtry.RBV CP")
    field(OUT,  "$(P)$(R)MotorYPos PP")
    field(PREC, "4")
}

record(ao, "$(P)$(R)MotorYPos") {
    field(DTYP, "asynFloat64")
    field(OUT,  "@asyn($(PORT),$(ADDR=0),$(TIMEOUT=1))DOT_MOTOR_Y_POS")
    field(PREC, "4")
}

record(ai, "$(P)$(R)MotorYPos_RBV") {
    field(DTYP, "asynFloat64")
    field(INP,  "@asyn($(PORT),$(ADDR=0),$(TIMEOUT=1))DOT_MOTOR_Y_POS")
    field(SCAN, "I/O Intr")
    field(PREC, "4")
}

record(ao, "$(P)$(R)BeamCurrentLink") {
    field(OMSL, "closed_loop")
    field(DOL,  "$(IOC)current CP")
    field(OUT,  "$(P)$(R)BeamCurrent PP")
    field(EGU,  "mA")
    field(PREC, "2")
}

record(ao, "$(P)$(R)BeamCurrent") {
    field(DTYP, "asynFloat64")
    field(OUT,  "@asyn($(PORT),$(ADDR=0),$(TIMEOUT=1))DOT_BEAM_CURRENT")
    field(EGU,  "mA")
    field(PREC, "2")
}

record(ai, "$(P)$(R)BeamCurrent_RBV") {
    field(DTYP, "asynFloat64")
    field(INP,  "@asyn($(PORT),$(ADDR=0),$(TIMEOUT=1))DOT_BEAM_CURRENT")
    field(SCAN, "I/O Intr")
    field(EGU,  "mA")
    field(PREC, "2")
}

record(bo, "$(P)$(R)ShutterOpen") {
    field(DTYP, "asynInt32")
    field(OUT,  "@asyn($(PORT),$(ADDR=0),$(TIMEOUT=1))DOT_SHUTTER_OPEN")
    field(ZNAM, "Closed")
    field(ONAM, "Open")
}

record(bi, "$(P)$(R)ShutterOpen_RBV") {
    field(DTYP, "asynInt32")
    field(INP,  "@asyn($(PORT),$(ADDR=0),$(TIMEOUT=1))DOT_SHUTTER_OPEN")
    field(SCAN, "I/O Intr")
    field(ZNAM, "Closed")
    field(ONAM, "Open")
}
